# =============================================================
# Folder Watcher — environment variables
# =============================================================

# --- Model provider --------------------------------------------
OPENCLAW_PROVIDER=anthropic
OPENCLAW_MODEL=claude-haiku-4-6   # cheap model is fine for short summaries

ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# --- Gateway --------------------------------------------------
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=3000
OPENCLAW_CHANNELS=web

# --- Workspace ------------------------------------------------
WORKSPACE_DIR=./workspace

# --- Folder watcher ------------------------------------------
WATCH_INBOX=workspace/inbox
WATCH_OUTPUT=workspace/summaries
WATCH_ARCHIVE=workspace/inbox/processed
WATCH_INTERVAL_MIN=1

GATEWAY_TZ=Europe/Berlin
