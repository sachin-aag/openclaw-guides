# =============================================================
# Scratchpad Assistant — environment variables
# =============================================================

# --- Model provider --------------------------------------------
OPENCLAW_PROVIDER=anthropic
OPENCLAW_MODEL=claude-sonnet-4-6

ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# --- Gateway --------------------------------------------------
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=3000
OPENCLAW_CHANNELS=web

# --- Workspace ------------------------------------------------
WORKSPACE_DIR=./workspace

# --- Scratchpad skill ----------------------------------------
SCRATCHPAD_FILE=notes.md

GATEWAY_TZ=Europe/Berlin
