# =============================================================
# Email Monitor — environment variables
# Copy this file to .env and fill in your values.
# =============================================================

# --- Model provider --------------------------------------------
# Pick one: anthropic, openai, google, local
OPENCLAW_PROVIDER=anthropic
OPENCLAW_MODEL=claude-sonnet-4-6

# Provide the matching API key for your chosen provider.
# Only set the one you're using.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# --- Gateway --------------------------------------------------
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=3000
OPENCLAW_CHANNELS=web

# --- Workspace ------------------------------------------------
WORKSPACE_DIR=./workspace

# --- Email monitor skill --------------------------------------
# Gmail IMAP credentials.
# You need a Gmail "App Password" (not your regular password).
# Guide: https://support.google.com/accounts/answer/185833
#
# Steps:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an app password for "Mail" on "Other (Custom name)"
#   4. Paste the 16-character password below (spaces don't matter)
EMAIL_USER=you@gmail.com
EMAIL_APP_PASSWORD=

# IMAP server settings (Gmail defaults — change if using another provider)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993

# How often to check for new emails (in minutes).
EMAIL_CHECK_INTERVAL_MIN=5

# Where email digests are saved.
EMAIL_DIGEST_DIR=workspace/email-digests

# --- Optional: timezone for cron in production ---------------
GATEWAY_TZ=Europe/Berlin
