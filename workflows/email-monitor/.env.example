# =============================================================
# Email Monitor — environment variables
# Copy this file to .env and fill in your values.
# =============================================================

# --- Model provider --------------------------------------------
# Pick one: anthropic, openai, google, featherless
OPENCLAW_PROVIDER=anthropic
OPENCLAW_MODEL=claude-sonnet-4-6

# Provide the matching API key for your chosen provider.
# Only set the one you're using.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# FEATHERLESS_API_KEY=

# --- Email monitor skill --------------------------------------
# Gmail IMAP credentials.
# You need a Gmail "App Password" (not your regular password).
# Guide: https://support.google.com/accounts/answer/185833
#
# Steps:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an app password for "Mail" on "Other (Custom name)"
#   4. Paste the 16-character password below (spaces don't matter)
EMAIL_USER=you@gmail.com
EMAIL_APP_PASSWORD=

# IMAP server settings (Gmail defaults — change if using another provider)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993

# Where email digests are saved.
EMAIL_DIGEST_DIR=workspace/email-digests

# --- Telegram delivery (optional) -----------------------------
# If both vars below are set, `npm run scan` also sends the digest
# to Telegram after writing it to disk. If either is empty, Telegram is
# skipped. See README.md "Step 2 — get digests on Telegram" for setup.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Interactive bot (optional, npm run bot) ------------------
# Comma-separated list of numeric Telegram user IDs allowed to send
# commands. Find your ID via @userinfobot. REQUIRED for `npm run bot` —
# without it, anyone who finds your bot username could run up your LLM
# bill. `npm run scan` does not read this var.
TELEGRAM_ALLOWED_USER_IDS=

# How often the bot's recurring scan fires, in minutes. Minimum 5.
# Cron pushes are urgent-only — quiet inboxes (no new mail, or no 🔴
# items) stay quiet so your phone isn't pinged for newsletters. Leave
# empty to disable the cron and only act on /scan commands.
EMAIL_SCAN_INTERVAL_MINUTES=30

# Per-user daily cap on /ask calls (the Q&A command grounded on the last
# 7 days of digests). Resets at local midnight. Default: 20.
ASK_DAILY_LIMIT=20

# Memory compaction triggers for /ask. Recent turns are kept verbatim and
# folded into a running summary when EITHER threshold trips. Lower numbers
# = more frequent compaction = more LLM calls but smaller per-turn prompts.
# Defaults are fine for most setups.
ASK_COMPACT_EVERY=5
ASK_COMPACT_AT_CHARS=6000
