# =============================================================
# Daily Review Agent — environment variables
# Copy this file to .env and fill in your values.
# =============================================================

# --- Model provider --------------------------------------------
# Pick one: anthropic, openai, google, local
OPENCLAW_PROVIDER=anthropic
OPENCLAW_MODEL=claude-sonnet-4-6

# Provide the matching API key for your chosen provider.
# Only set the one you're using.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# --- Gateway --------------------------------------------------
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=3000
OPENCLAW_CHANNELS=web

# --- Workspace ------------------------------------------------
# Folder where SOUL.md / USER.md / MEMORY.md / notes/ live.
WORKSPACE_DIR=./workspace

# --- Daily review skill --------------------------------------
# How many days back to summarize. 1 = yesterday only.
REVIEW_LOOKBACK_DAYS=1

# Output filename (overwritten on each run — by design, idempotent).
REVIEW_OUTPUT=daily-review.md

# --- Optional: timezone for cron in production ---------------
# Only used when deployed to a VPS. Local dev ignores this.
GATEWAY_TZ=Europe/Berlin
