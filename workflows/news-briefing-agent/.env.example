# =============================================================
# News Briefing Agent — environment variables
# Copy this file to .env and fill in your values.
# =============================================================

# --- Model provider --------------------------------------------
# Pick one: anthropic, openai, google, featherless
OPENCLAW_PROVIDER=anthropic
OPENCLAW_MODEL=claude-sonnet-4-6

# Provide the matching API key for your chosen provider.
# Only set the one you're using.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# FEATHERLESS_API_KEY=

# --- News briefing skill --------------------------------------
# Path to the file listing RSS feed URLs (one per line).
FEEDS_FILE=workspace/feeds.txt

# Where generated briefings are saved.
BRIEFING_OUTPUT_DIR=workspace/briefings

# --- Telegram delivery (optional) -----------------------------
# If both vars below are set, `npm run briefing` also sends the briefing
# to Telegram after writing it to disk. If either is empty, Telegram is
# skipped. See README.md "Step 2 — get briefings on Telegram" for setup.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Interactive bot (optional, npm run bot) ------------------
# Comma-separated list of numeric Telegram user IDs allowed to send
# commands. Find your ID via @userinfobot. REQUIRED for `npm run bot` —
# without it, anyone who finds your bot username could run up your LLM
# bill. `npm run briefing` does not read this var.
TELEGRAM_ALLOWED_USER_IDS=

# Hour of day (0–23, local time) when the bot regenerates the daily
# briefing on its own. Leave empty to disable the cron and only act on
# /briefing commands. Only used by `npm run bot`.
BRIEFING_CRON_HOUR=8

# Per-user daily cap on /ask calls (the Q&A command grounded on the last
# 7 days of briefings). Resets at local midnight. Default: 20.
ASK_DAILY_LIMIT=20

# Memory compaction triggers for /ask. Recent turns are kept verbatim and
# folded into a running summary when EITHER threshold trips. Lower numbers
# = more frequent compaction = more LLM calls but smaller per-turn prompts.
# Defaults are fine for most setups.
ASK_COMPACT_EVERY=5
ASK_COMPACT_AT_CHARS=6000
