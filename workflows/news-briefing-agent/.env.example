# =============================================================
# News Briefing Agent — environment variables
# Copy this file to .env and fill in your values.
# =============================================================

# --- Model provider --------------------------------------------
# Pick one: anthropic, openai, google, local
OPENCLAW_PROVIDER=anthropic
OPENCLAW_MODEL=claude-sonnet-4-6

# Provide the matching API key for your chosen provider.
# Only set the one you're using.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# --- Gateway --------------------------------------------------
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=3000
OPENCLAW_CHANNELS=web

# --- Workspace ------------------------------------------------
# Folder where SOUL.md / USER.md / MEMORY.md live.
WORKSPACE_DIR=./workspace

# --- News briefing skill --------------------------------------
# Path to the file listing RSS feed URLs (one per line).
FEEDS_FILE=workspace/feeds.txt

# Where generated briefings are saved.
BRIEFING_OUTPUT_DIR=workspace/briefings

# --- Optional: Telegram notifications ------------------------
# Create a bot via @BotFather on Telegram. Set the token and your
# user ID to receive briefing summaries in Telegram.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USER_IDS=

# --- Optional: timezone for cron in production ---------------
# Only used when deployed to a VPS. Local dev ignores this.
GATEWAY_TZ=Europe/Berlin
