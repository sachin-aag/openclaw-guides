# =============================================================
# Price Monitor — environment variables
# Copy this file to .env and fill in your values.
# =============================================================

# --- Model provider --------------------------------------------
# Pick one: anthropic, openai, google, featherless
OPENCLAW_PROVIDER=anthropic
OPENCLAW_MODEL=claude-sonnet-4-6

# Provide the matching API key for your chosen provider.
# Only set the one you're using.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# FEATHERLESS_API_KEY=

# --- Price monitor skill --------------------------------------
# Path to the YAML file defining what to watch.
WATCHLIST_FILE=workspace/watchlist.yaml

# Where price check logs are appended.
PRICE_LOG_FILE=workspace/price-log.md

# How many items to check in parallel. Each item is one curl + one LLM
# call, so this also caps concurrent requests to your model provider.
# Default 4 scales reasonably from the shipped 4-item watchlist (one
# batch) to ~30 items (~8 batches, ~25-40s total) without hammering
# free-tier rate limits. Set to 1 to force sequential, or raise it on
# a paid plan with many items.
PRICE_CHECK_CONCURRENCY=4

# --- Telegram delivery (optional) -----------------------------
# If both vars below are set, the CLI (`npm run check`) sends a summary
# to Telegram, and the bot's recurring cron pushes ALERTS ONLY to this
# chat. If either is empty, Telegram is skipped. See README.md
# "Step 2 — get checks on Telegram" for setup.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Interactive bot (optional, npm run bot) ------------------
# Comma-separated list of numeric Telegram user IDs allowed to send
# commands. Find your ID via @userinfobot. REQUIRED for `npm run bot` —
# without it, anyone who finds your bot username could run up your LLM
# bill. `npm run check` does not read this var.
TELEGRAM_ALLOWED_USER_IDS=

# How often the bot re-checks prices on its own, in minutes. Minimum 5.
# Cron-mode delivery is alerts-only — quiet runs stay quiet so your
# phone isn't pinged for "everything is fine" every hour. Leave empty
# to disable the recurring check and only act on /check commands.
# Only used by `npm run bot`.
PRICE_CHECK_INTERVAL_MINUTES=60

# Per-user daily cap on /ask calls (the Q&A command grounded on the
# last 7 days of price-log entries). Resets at local midnight. Default: 20.
ASK_DAILY_LIMIT=20

# Memory compaction triggers for /ask. Recent turns are kept verbatim
# and folded into a running summary when EITHER threshold trips. Lower
# numbers = more frequent compaction = more LLM calls but smaller
# per-turn prompts. Defaults are fine for most setups.
ASK_COMPACT_EVERY=5
ASK_COMPACT_AT_CHARS=6000
