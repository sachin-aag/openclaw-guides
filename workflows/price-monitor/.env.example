# =============================================================
# Price Monitor — environment variables
# Copy this file to .env and fill in your values.
# =============================================================

# --- Model provider --------------------------------------------
# Pick one: anthropic, openai, google, local
OPENCLAW_PROVIDER=anthropic
OPENCLAW_MODEL=claude-sonnet-4-6

# Provide the matching API key for your chosen provider.
# Only set the one you're using.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# --- Gateway --------------------------------------------------
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=3000
OPENCLAW_CHANNELS=web

# --- Workspace ------------------------------------------------
WORKSPACE_DIR=./workspace

# --- Price monitor skill --------------------------------------
# Path to the YAML file defining what to watch.
WATCHLIST_FILE=workspace/watchlist.yaml

# Where price check logs are appended.
PRICE_LOG_FILE=workspace/price-log.md

# How often to check prices (in minutes). Used by the heartbeat.
MONITOR_INTERVAL_MIN=15

# --- Optional: Telegram notifications ------------------------
# Create a bot via @BotFather on Telegram. Set the token and your
# user ID to receive price alerts in Telegram.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USER_IDS=

# --- Optional: timezone for cron in production ---------------
GATEWAY_TZ=Europe/Berlin
